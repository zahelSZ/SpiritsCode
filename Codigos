-- ========================================================
for i = 1, 8 do
	local barrierGroupName = "Barrier" .. i
	local ownerGroupName = "Owner" .. i

	pcall(function() PhysicsService:RegisterCollisionGroup(barrierGroupName) end)
	pcall(function() PhysicsService:RegisterCollisionGroup(ownerGroupName) end)

	-- REGLA MAESTRA: El dueño de la base 'i' NO choca con la barrera de la base 'i'
	PhysicsService:CollisionGroupSetCollidable(ownerGroupName, barrierGroupName, false)
end

