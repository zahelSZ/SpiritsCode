	textLabel.BackgroundTransparency = 1
	textLabel.Text = "-" .. tostring(damageAmount)
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextSize = 22

	-- Color dinámico: Si el daño es devastador, se pone rojo intenso
