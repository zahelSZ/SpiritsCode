	MultiplierFormula = function(currentRebirth: number): number
		return currentRebirth + 1
	end,

	SlotsFormula = function(currentRebirth: number): number
		return currentRebirth + 1
	end,

	CritBonusPerRebirth = 1
}

local RebirthEvents = Instance.new("RemoteEvent")
RebirthEvents.Name = "RebirthEvents"
RebirthEvents.Parent = ReplicatedStorage

local RebirthManager = {}

-- Debounce simple
local lastRebirth = {}

function RebirthManager.CanRebirth(player: Player): (boolean, string)
	if not player or not player:IsA("Player") then
		return false, "Jugador inválido"
	end

	local data = DataManager.GetData(player)
	if not data then
		return false, "Datos no cargados"
	end

	if data.HeldSpirit or player:GetAttribute("IsCarryingSpirit") then
		return false, "No puedes renacer mientras llevas un Spirit"
	end

	local costo = RebirthConfig.CostFormula(data.Rebirths)
	if data.Esencia < costo then
		return false, string.format("Necesitas %d de esencia", costo)
	end

	return true, "Listo para renacer"
end

function RebirthManager.DoRebirth(player: Player): boolean
	-- Debounce
	if lastRebirth[player] and os.clock() - lastRebirth[player] < 2 then
		return false
	end
	lastRebirth[player] = os.clock()

	local puede, motivo = RebirthManager.CanRebirth(player)
	if not puede then
		RebirthEvents:FireClient(player, "Fallido", motivo)
		return false
	end

	local data = DataManager.GetData(player)
	local rebirthsAnteriores = data.Rebirths

	-- 🧹 Limpiar Spirits de la base (mejorar esto después)
	local baseNum = player:GetAttribute("BaseNumber")
	if baseNum then
		local baseObj = Workspace:FindFirstChild("base" .. baseNum)
		if baseObj and baseObj:FindFirstChild("based") and baseObj.based:FindFirstChild("base") then
			local baseFolder = baseObj.based.base
			for _, obj in ipairs(baseFolder:GetChildren()) do
				if obj:IsA("BasePart") and obj.Name:match("^slot%d+$") then
					local spirit = obj:FindFirstChild("Spirit") or obj:FindFirstChild("Orbe")
					if spirit then spirit:Destroy() end
				end
			end
		end
	end

	-- 📉 Reset + aplicar beneficios permanentes
	DataManager.UpdateData(player, function(d)
		d.Esencia = 0
		d.HeldSpirit = nil
		d.Spirits = {}

		d.Turret.Stats = {
			Damage = 10, ProjectileSpeed = 450, ProjectileSize = 4,
			FireRate = 0.15, Range = 200, CritChance = 0, MultiShot = 1,
		}
		d.Turret.Levels = {
			Damage = 0, ProjectileSpeed = 0, ProjectileSize = 0,
			FireRate = 0, Range = 0, CritChance = 0, MultiShot = 0,
		}

		d.Rebirths = rebirthsAnteriores + 1
		d.MultiplicadorEsencia = RebirthConfig.MultiplierFormula(d.Rebirths)
		d.EspaciosMaxBase = RebirthConfig.SlotsFormula(d.Rebirths)
		d.BonoCriticoPorcentual = d.Rebirths * RebirthConfig.CritBonusPerRebirth

		return d
	end)

	-- 🔄 Obtener datos actualizados
	data = DataManager.GetData(player)
	DataManager.SaveData(player)

	RebirthEvents:FireClient(player, "Exitoso", {
		Rebirths = data.Rebirths,
		Multiplicador = data.MultiplicadorEsencia,
		Espacios = data.EspaciosMaxBase,
		CriticoExtra = data.BonoCriticoPorcentual
	})

	print(string.format("[RebirthManager] ✅ %s → Rebirth %d", player.Name, data.Rebirths))
	return true
end

function RebirthManager.GetInfo(player: Player): {}?
	local data = DataManager.GetData(player)
	if not data then return nil end

	return {
		Actual = data.Rebirths,
		CostoSiguiente = RebirthConfig.CostFormula(data.Rebirths),
		Multiplicador = data.MultiplicadorEsencia,
		EspaciosMax = data.EspaciosMaxBase,
		BonoCritico = data.BonoCriticoPorcentual
	}
end

-- Conexiones
RebirthEvents.OnServerEvent:Connect(function(player: Player, accion: string)
	if accion == "HacerRebirth" then
		RebirthManager.DoRebirth(player)
	elseif accion == "PedirInfo" then
		local info = RebirthManager.GetInfo(player)
		if info then
			RebirthEvents:FireClient(player, "InfoActual", info)
		end
	end
end)

-- Corrección al entrar
Players.PlayerAdded:Connect(function(player: Player)
	task.spawn(function()
		repeat task.wait(0.1) until DataManager.GetData(player) or not player:IsDescendantOf(Players)
		local data = DataManager.GetData(player)
		if not data then return end

		DataManager.UpdateData(player, function(d)
			d.MultiplicadorEsencia = RebirthConfig.MultiplierFormula(d.Rebirths)
			d.EspaciosMaxBase = RebirthConfig.SlotsFormula(d.Rebirths)
			d.BonoCriticoPorcentual = d.Rebirths * RebirthConfig.CritBonusPerRebirth
			return d
		end)
	end)
end)

return RebirthManager

