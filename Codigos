local function getTargetPlayer(name)
	if not name or name == "" then return nil end
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Name:lower() == name:lower() or p.DisplayName:lower() == name:lower() then
			return p
		end
	end
	return nil
end

local function setEsencia(player, amount)
	local esencia = player.leaderstats and player.leaderstats:FindFirstChild("Esencia")
	if esencia then
		esencia.Value = math.clamp(amount, 0, 999999999999) 
		DataManager.UpdateData(player, function(data)
			data.Esencia = esencia.Value
			return data
		end)
		return true
	end
	return false
end

