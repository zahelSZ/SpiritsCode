local function getRandomRarity()
	if math.random(1, 100000000) == 1 then
		return {Name = "Especial", BoxHealth = 10000000, RarityKey = "Especial"}
	end
	local total = 0
	for _, r in ipairs(RarityTable) do total += r.Chance end
	local roll = math.random() * total
	local sum = 0
	for _, rarity in ipairs(RarityTable) do
		sum += rarity.Chance
		if roll <= sum then return rarity end
	end
	return RarityTable[1]
end

local function getRandomSpirit(rarityKey)
	if rarityKey == "Especial" then
		for _, s in ipairs(SpiritDatabase) do
			if s.Name == "Espiritu Santo" then return s end
		end
	end
	local weights = RarityWeights[rarityKey]
	if not weights then return nil end
	local total = 0
	for _, w in pairs(weights) do total += w end
	local roll = math.random() * total
	local sum = 0
	for name, weight in pairs(weights) do
		sum += weight
		if roll <= sum then
			for _, spirit in ipairs(SpiritDatabase) do
				if spirit.Name == name then return spirit end
			end
		end
	end
	for _, spirit in ipairs(SpiritDatabase) do
		if spirit.Rarity == rarityKey then return spirit end
	end
	return nil
end

