	local data = sessionData[player]
	if not data then return false, "No se encontraron datos del jugador" end

	if not data.Equipos then data.Equipos = {} end

	if data.Equipos[equipoNombre] then
		return false, "Ya existe un equipo con ese nombre"
	end

	if #data.Equipos >= MAX_EQUIPOS then
		return false, "Ya tienes el máximo de equipos permitidos (" .. MAX_EQUIPOS .. ")"
	end

	data.Equipos[equipoNombre] = {
		Spirits = {} -- Lista de Spirits en el equipo
	}

	return true
end

-- Agregar un Spirit a un equipo con rol
function DataManager.AddSpiritToEquipo(player, equipoNombre, spiritName, rol)
	local data = sessionData[player]
	if not data or not data.Equipos or not data.Equipos[equipoNombre] then
		return false, "Equipo no encontrado"
	end

	local equipo = data.Equipos[equipoNombre]

	if #equipo.Spirits >= MAX_SPIRITS_POR_EQUIPO then
		return false, "El equipo ya está lleno (máximo " .. MAX_SPIRITS_POR_EQUIPO .. " Spirits)"
	end

	-- Verificar que el Spirit no esté ya en este equipo
	for _, s in ipairs(equipo.Spirits) do
		if s.SpiritName == spiritName then
			return false, "Este Spirit ya está en el equipo"
		end
	end

	table.insert(equipo.Spirits, {
		SpiritName = spiritName,
		Rol = rol or "Sin rol"
	})

	return true
