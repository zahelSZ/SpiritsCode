--!strict
-- Script: BaseAssignment (Versión Anti-Reset de Avatar)
-- Ubicación: ServerScriptService
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local assignedBases = {}

local function updatePublicCartel(baseNumber, playerName)
	local base = Workspace:FindFirstChild("base" .. baseNumber)
	if not base then return end

	local ownerUI = base:FindFirstChild("BaseOwnerUI" .. baseNumber)
	if not ownerUI then return end

	local cartel = ownerUI:FindFirstChild("cartel")
	if not cartel then return end

	local surfaceGui = cartel:FindFirstChild("OwnerLabel") or Instance.new("SurfaceGui")
	surfaceGui.Name = "OwnerLabel"
	surfaceGui.Face = Enum.NormalId.Front
	surfaceGui.SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud
	surfaceGui.PixelsPerStud = 25
	surfaceGui.Parent = cartel

	local textLabel = surfaceGui:FindFirstChild("TextLabel") or Instance.new("TextLabel")
	textLabel.Name = "TextLabel"
	textLabel.Size = UDim2.new(1, 0, 1, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.Text = "Base de " .. playerName
	textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	textLabel.TextScaled = true
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextStrokeTransparency = 0.4
	textLabel.Parent = surfaceGui
end

-- Función interna que aplica el grupo de colisión de forma estricta
local function applyCollisionGroup(character, baseNumber)
	local groupName = "Owner" .. baseNumber
	local partsCount = 0

	for _, part in pairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CollisionGroup = groupName
			partsCount = partsCount + 1
		end
	end

	print("👤 [BaseAssignment] ¡Éxito! " .. partsCount .. " partes de " .. character.Name .. " asignadas a " .. groupName)
end

local function setCharacterCollisionGroup(character, baseNumber)
	-- 1. Intento inmediato al spawnear
	applyCollisionGroup(character, baseNumber)

	-- 2. SOLUCIÓN AL RESET DE ROBLOX: Volver a aplicar cuando la ropa y accesorios carguen al 100%
	local player = Players:GetPlayerFromCharacter(character)
	if player then
		player.CharacterAppearanceLoaded:Connect(function(loadedCharacter)
			applyCollisionGroup(loadedCharacter, baseNumber)
		end)
	end

	-- 3. Escudo para herramientas que se equipen después
	character.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("BasePart") then
			descendant.CollisionGroup = "Owner" .. baseNumber
		end
	end)
end

local function assignBase(player)
	for i = 1, 8 do
		if not assignedBases[i] then
			assignedBases[i] = player
			player:SetAttribute("BaseNumber", i)
			updatePublicCartel(i, player.DisplayName)
			return i
		end
	end
	return nil
end

local function spawnPlayer(player, baseNumber)
	local spawnFolder = Workspace:FindFirstChild("spawns")
	if not spawnFolder then return end

	local spawn = spawnFolder:FindFirstChild("SpawnLocation" .. baseNumber)
	if spawn and spawn:IsA("SpawnLocation") then
		player.RespawnLocation = spawn
	end
end

local function onPlayerAdded(player)
	local baseNumber = assignBase(player)
	if baseNumber then
		spawnPlayer(player, baseNumber)
	end

	player.CharacterAdded:Connect(function(character)
		local num = player:GetAttribute("BaseNumber")
		if num then
			setCharacterCollisionGroup(character, num)
			spawnPlayer(player, num)
		end
	end)

	if player.Character then
		local num = player:GetAttribute("BaseNumber")
		if num then
			setCharacterCollisionGroup(player.Character, num)
			spawnPlayer(player, num)
		end
	end
end

Players.PlayerAdded:Connect(onPlayerAdded)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, player)
end

Players.PlayerRemoving:Connect(function(player)
	local num = player:GetAttribute("BaseNumber")
	if num then
		assignedBases[num] = nil
	end
end)

