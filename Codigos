-- Objetivo: Dictador único de la posición, rotación y estética de los Spirits en los slots.

local SpiritPositionManager = {}

type SpiritConfig = {
	Offset: Vector3,
	Rotation: Vector3, -- En grados (0 a 360)
}

-- 📋 TABLA DE CONFIGURACIÓN CENTRALIZADA (CORREGIDA)
-- Los nombres aquí deben coincidir EXACTAMENTE con tu SpiritDatabase
local CONFIG_TABLE: { [string]: SpiritConfig } = {
	["Default"] = {
		Offset = Vector3.new(0, 2.5, 0),
		Rotation = Vector3.new(0, 0, 0)
	},
	["Espiritu de Tierra"] = {
		Offset = Vector3.new(0, 2.2, 0), -- ¡Ahora sí puedes bajarlo o subirlo aquí!
		Rotation = Vector3.new(0, 0, 0)
	},
	["Espiritu de Brisa"] = {
		Offset = Vector3.new(0, 3.5, 0), -- Ajusta su altura de flotación
		Rotation = Vector3.new(0, 45, 0) -- Rotación estilizada en 45 grados
	},
	["Espiritu de Fuego"] = {
		Offset = Vector3.new(0, 2.5, 0),
		Rotation = Vector3.new(0, 90, 0)
	}
}

-- ⚡ FUNCIÓN CENTRAL: COLOCAR EN SLOT
function SpiritPositionManager.PlaceInSlot(spirit: Instance, slot: BasePart)
	if not spirit or not slot then return end

	-- 1. Identificar el Spirit mediante su Atributo de base de datos
	local spiritName = spirit:GetAttribute("SpiritName") or spirit.Name
	local config = CONFIG_TABLE[spiritName] or CONFIG_TABLE["Default"]

	-- 2. Calcular el CFrame del objetivo combinando la posición del slot + offsets personalizados
	local slotCFrame = slot.CFrame
	local offsetCFrame = CFrame.new(config.Offset) * CFrame.Angles(
		math.rad(config.Rotation.X),
		math.rad(config.Rotation.Y),
		math.rad(config.Rotation.Z)
	)
	local targetCFrame = slotCFrame * offsetCFrame

	-- 3. Mover el objeto físicamente (Maneja tanto Parts antiguas como los nuevos Models de Blender)
	if spirit:IsA("Model") then
		spirit:PivotTo(targetCFrame)
	elseif spirit:IsA("BasePart") then
		spirit.CFrame = targetCFrame
	end

	-- 4. Asignar jerarquía en el Workspace
	spirit.Parent = slot

	-- 5. Asegurar físicas (Fijar posición y remover colisiones para evitar lag de físicas)
	if spirit:IsA("Model") then
		for _, descendant in ipairs(spirit:GetDescendants()) do
			if descendant:IsA("BasePart") then
				descendant.Anchored = true
				descendant.CanCollide = false
			end
		end
	elseif spirit:IsA("BasePart") then
		spirit.Anchored = true
		spirit.CanCollide = false
	end
end

return SpiritPositionManager

