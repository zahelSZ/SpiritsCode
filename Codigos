local function spawnBox(forcedRarity)
	local rarity = forcedRarity or getRandomRarity()

	local spawnFolder = Workspace:FindFirstChild("SpawnArea")
	if not spawnFolder then return end
	local centerPart = spawnFolder:FindFirstChild("SpawnCenter")
	if not centerPart or not centerPart:FindFirstChild("Radius") then return end

	local centerPos = centerPart.Position
	local radius = centerPart.Radius.Value
	local angle = math.random() * math.pi * 2
	local dist = math.random() * radius
	local spawnPos = Vector3.new(
		centerPos.X + math.cos(angle) * dist,
		SPAWN_HEIGHT,
		centerPos.Z + math.sin(angle) * dist
	)

	local box = getCrateModel(rarity.Name)
	if not box then
		box = Instance.new("Part")
		box.Size = Vector3.new(12, 12, 12) -- Ajustado al estándar de Tom Studios™
		box.Material = Enum.Material.Neon
	end

	box.Name = "Caja_" .. rarity.Name
	box.Position = spawnPos
	box.Anchored = false
	box.CanCollide = true
	box.Parent = Workspace

	local health = Instance.new("IntValue")
	health.Name = "Health"
	health.Value = rarity.BoxHealth
	health.Parent = box

	local breaker = Instance.new("ObjectValue")
	breaker.Name = "Breaker"
	breaker.Value = nil
	breaker.Parent = box

	local bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(0, math.huge, 0)
	bv.Velocity = Vector3.new(0, -28, 0)
	bv.Parent = box

	-- Iniciar la creación de la interfaz de la caja
	createBoxBillboard(box, rarity.Name, rarity.BoxHealth)

	local landed = false
	box.Touched:Connect(function()
		if landed then return end
		if box.Position.Y < 56.3 then
			landed = true
			if bv and bv.Parent then bv:Destroy() end
			box.Anchored = true
			box.Velocity = Vector3.zero
			box.Position = Vector3.new(box.Position.X, 52.5, box.Position.Z)
			CreateCrater(box.Position, box)

			-- ⏳ Temporizador en tiempo real exclusivo al aterrizar
			task.spawn(function()
				local info = box:FindFirstChild("CrateInfo")
				local timerLabel = info and info.Frame:FindFirstChild("TimerLabel")
				for seconds = 60, 0, -1 do
					if not box or not box.Parent then break end
