-- Script: CrowbarServer (CORREGIDO)
-- Ubicación: StarterPack -> Crowbar

local Tool = script.Parent
local AttackEvent = Tool:WaitForChild("CrowbarAttack")
local ServerScriptService = game:GetService("ServerScriptService")
local SpeedManager = require(ServerScriptService:WaitForChild("SpeedManager"))

local COOLDOWN = 0.6
local DAMAGE = 25
local lastAttack = {}

AttackEvent.OnServerEvent:Connect(function(player)
	local character = player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not character or not rootPart or character:GetAttribute("IsStunned") then return end

	-- Cooldown Anti-Spam
	local now = tick()
	if lastAttack[player] and (now - lastAttack[player]) < COOLDOWN then return end
	lastAttack[player] = now

	local hitBoxParam = OverlapParams.new()
	hitBoxParam.FilterDescendantsInstances = {character}
	hitBoxParam.FilterType = Enum.RaycastFilterType.Exclude

	local hitTargets = {}

	-- ========================================================
	-- 📦 HITBOX 1: DETECCIÓN DE CAJAS (Grande y Ajustada al Nombre)
	-- ========================================================
	-- Detección de 12x12x12 hacia el frente
	local boxHitParts = workspace:GetPartBoundsInBox(rootPart.CFrame * CFrame.new(0, 0, 0), Vector3.new(12, 12, 12), hitBoxParam)
	local boxHit = false

	for _, part in pairs(boxHitParts) do
		-- Buscar la caja en el part mismo o en su padre
		local box = nil
		if string.find(part.Name, "Caja_") and part.Anchored == true then
			box = part
		elseif part.Parent and string.find(part.Parent.Name, "Caja_") and part.Parent:FindFirstChild("Health") then
			box = part.Parent
		end

		if box and not hitTargets[box] then
			hitTargets[box] = true
			_G.DamageBox(box, DAMAGE, player)
			boxHit = true
			break
		end
	end
	

	-- Si golpeamos una caja, no permitimos golpear jugadores en el mismo ataque
	if boxHit then return end

	-- ========================================================
	-- 👤 HITBOX 2: DETECCIÓN DE JUGADORES (4x4x5)
	-- ========================================================
	local playerHitParts = workspace:GetPartBoundsInBox(rootPart.CFrame * CFrame.new(0, 0, -3), Vector3.new(4, 4, 5), hitBoxParam)

	for _, part in pairs(playerHitParts) do
		local targetChar = part.Parent
		local targetHumanoid = targetChar and targetChar:FindFirstChildOfClass("Humanoid")

		if targetHumanoid and targetHumanoid.Health > 0 and not targetChar:GetAttribute("IsStunned") then
			local targetPlayer = game.Players:GetPlayerFromCharacter(targetChar)
			local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")

			if targetPlayer and targetRoot and not hitTargets[targetChar] then
				hitTargets[targetChar] = true

				-- Soltar Spirit
				if targetChar:GetAttribute("HasSpirit") then
					targetChar:SetAttribute("HasSpirit", false)
					SpeedManager.UpdateSpeed(targetPlayer)
					-- Aquí tu función global de dropeo: _G.DropSpirit(targetPlayer)
				end

				-- Aplicar Stun
				targetChar:SetAttribute("IsStunned", true)
				SpeedManager.UpdateSpeed(targetPlayer)
				targetHumanoid:UnequipTools()
				targetHumanoid.PlatformStand = true

				-- Física de Empuje
				local pushDirection = (targetRoot.Position - rootPart.Position).Unit
				targetRoot.AssemblyLinearVelocity = (pushDirection * 50) + Vector3.new(0, 30, 0)

				-- Recuperación
				task.spawn(function()
					task.wait(0.5)
					while targetRoot and targetRoot.AssemblyLinearVelocity.Magnitude > 1 do
						task.wait(0.1)
					end
					task.wait(math.random(3, 5) / 10)
					if targetChar and targetHumanoid then
						targetHumanoid.PlatformStand = false
						targetChar:SetAttribute("IsStunned", false)
						SpeedManager.UpdateSpeed(targetPlayer)
					end
				end)
				break 
			end
		end
	end
end)

