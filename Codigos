local function startCarrying(ply, spr)
	if not ply or not spr then return end
	carrying[ply] = spr
	ply:SetAttribute("IsCarryingSpirit", true)
	spr:SetAttribute("SpiritState", "Holding")

	-- ✨ SOLUCIÓN: Le ponemos "HasSpirit" al Character para que el SpeedManager lo lea
	if ply.Character then
		ply.Character:SetAttribute("HasSpirit", true)
	end
	SpeedManager.UpdateSpeed(ply)
end

local function stopCarrying(ply)
	if not ply then return end
	local spr = carrying[ply]
	carrying[ply] = nil
	ply:SetAttribute("IsCarryingSpirit", false)

	-- ✨ SOLUCIÓN: Limpiamos el "HasSpirit" del Character al soltarlo
	if ply.Character then
		ply.Character:SetAttribute("HasSpirit", false)
	end
	SpeedManager.UpdateSpeed(ply)

	if carryConnections[ply] then
		carryConnections[ply]:Disconnect()
		carryConnections[ply] = nil
	end
	if spr and spr.Parent then
		local state = spr:GetAttribute("SpiritState")
		if state == "Holding" then
			spr:SetAttribute("SpiritState", "World")
			_G.ScheduleSpiritDestroy(spr)
		end
	end
end

-- ====================== FUNCIÓN CENTRALIZADA DE RECOGIDA ======================
local SpiritUtils = require(ServerScriptService:WaitForChild("SpiritUtils"))

local function setupSpiritPickup(spirit)
	if not spirit or not spirit.Parent then return end
	if spirit:GetAttribute("IsBeingCarried") then return end
	if spirit:FindFirstChildOfClass("ProximityPrompt") then return end

	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = "Recoger Spirit"
	prompt.ObjectText = "Spirit"
	prompt.HoldDuration = 0.5
	prompt.MaxActivationDistance = 10
	prompt.Parent = spirit

	prompt.Triggered:Connect(function(player)
		if carrying[player] then return end

		local originSlot = spirit.Parent
		if originSlot and not string.match(originSlot.Name, "slot") then
			originSlot = nil
		end

		spirit:SetAttribute("IsBeingCarried", true)

		-- Limpiar fuerzas y físicas
		for _, v in spirit:GetChildren() do
			if v:IsA("BodyVelocity") or v:IsA("VectorForce") or v:IsA("WeldConstraint") then
				v:Destroy()
			end
		end

		SpiritUtils.ClearVelocities(spirit)
		SpiritUtils.SetAnchored(spirit, true)
		SpiritUtils.SetCanCollide(spirit, false)

		startCarrying(player, spirit)

		if spirit:GetAttribute("FromSlot") then
			print("[OrbSystem] Spirit de slot recogido de: " .. (originSlot and originSlot.Name or "Desconocido"))

			local baseNum = player:GetAttribute("BaseNumber")
			if baseNum and originSlot then
				local slotNum = tonumber(string.match(originSlot.Name, "%d+"))
				if slotNum then
					local DataManager = require(game:GetService("ServerScriptService"):WaitForChild("DataManager"))
					local spiritName = spirit:GetAttribute("SpiritName") or spirit.Name

					DataManager.SetHeldSpirit(player, spiritName, baseNum, slotNum)
					DataManager.RemoveSpiritFromSlot(player, baseNum, slotNum)
					print("[OrbSystem] Spirit en transito guardado en HeldSpirit")
				end
			end

			-- Lógica de prompts para colocar/intercambiar (se mantiene igual)
			local baseNum = player:GetAttribute("BaseNumber")
			if baseNum then
				local playerBase = Workspace:FindFirstChild("base" .. baseNum)
				local baseFolder = playerBase and playerBase:FindFirstChild("based") and playerBase.based:FindFirstChild("base")

				if baseFolder then
					local activeSlotPrompts = {}

					for s = 1, 10 do
						local slot = baseFolder:FindFirstChild("slot" .. s)
						if slot and slot:IsA("BasePart") then
							local occupantSpirit = slot and SpiritUtils.GetSpiritInSlot(slot) or nil

							local slotPrompt = Instance.new("ProximityPrompt")
							slotPrompt.Name = "MoveSpiritPrompt"
							slotPrompt.HoldDuration = 0.5
							slotPrompt.MaxActivationDistance = 6
							slotPrompt.Exclusivity = Enum.ProximityPromptExclusivity.OnePerButton
							slotPrompt.Parent = slot

							if occupantSpirit then
								slotPrompt.ActionText = "Intercambiar Spirit"
								slotPrompt.ObjectText = "Slot " .. s .. " (Ocupado)"
							else
								slotPrompt.ActionText = "Colocar aquí"
								slotPrompt.ObjectText = "Slot " .. s
							end

							table.insert(activeSlotPrompts, slotPrompt)

							slotPrompt.Triggered:Connect(function(p)
								if p ~= player or carrying[p] ~= spirit then return end

								print("[OrbSystem] Procesando colocación en slot " .. s)
								spirit:SetAttribute("SpiritState", "Base")
								stopCarrying(p)

								local targetOccupant = SpiritUtils.GetSpiritInSlot(slot)

								if targetOccupant and targetOccupant ~= spirit then
									if originSlot then
										print("[OrbSystem] Intercambiando: Mandando " .. targetOccupant.Name .. " a " .. originSlot.Name)

										local occPrompt = targetOccupant:FindFirstChildOfClass("ProximityPrompt")
										if occPrompt then occPrompt:Destroy() end

										SpiritPositionManager.PlaceInSlot(targetOccupant, originSlot)

										task.defer(function()
											setupSpiritPickup(targetOccupant)
										end)
									else
										print("[OrbSystem] No hay slot de origen para intercambiar. Acción cancelada.")
										startCarrying(p, spirit)
										return
									end
								end

								-- Colocar el Spirit que llevamos
								spirit.Parent = slot
								SpiritPositionManager.PlaceInSlot(spirit, slot)
								spirit:SetAttribute("IsBeingCarried", nil)

								for _, sPrompt in ipairs(activeSlotPrompts) do
									if sPrompt and sPrompt.Parent then sPrompt:Destroy() end
								end
								table.clear(activeSlotPrompts)

								task.wait(0.1)
								setupSpiritPickup(spirit)
							end)
						end
					end
				end
			end
		end

		if prompt and prompt.Parent then
			prompt:Destroy()
		end

		-- Loop para seguir al jugador mientras lo carga
		local connection
		connection = RunService.Heartbeat:Connect(function()
			if carrying[player] ~= spirit then
				if connection then connection:Disconnect() end
				return
			end

			if not spirit or not spirit.Parent or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
