local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local OpenBaseEvent = ReplicatedStorage:WaitForChild("OpenBaseEvent")

local player = game.Players.LocalPlayer

local function createTimer(baseNumber, mode)
	-- Buscar la base correcta dinámicamente
	local baseModel = Workspace:FindFirstChild("base" .. baseNumber)
	if not baseModel then
		warn("No se encontró base" .. baseNumber)
		return
	end

	local based = baseModel:FindFirstChild("based")
	local caja = based and based:FindFirstChild("caja de fusible")
	local promptPart = caja and caja:FindFirstChild("PromptPart")

	if not promptPart then
		warn("No se encontró PromptPart en base" .. baseNumber)
		return
	end

	-- Eliminar timer anterior si existe (evita duplicados)
	local oldBillboard = promptPart:FindFirstChild("TimerBillboard")
	if oldBillboard then
		oldBillboard:Destroy()
	end

	-- Crear BillboardGui
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "TimerBillboard"
	billboard.Size = UDim2.new(0, 120, 0, 50)
	billboard.StudsOffset = Vector3.new(0, 4.5, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 80
	billboard.Adornee = promptPart
	billboard.Parent = promptPart

	local label = Instance.new("TextLabel")
	label.Name = "TimerLabel"
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.TextStrokeTransparency = 0.3
	label.Parent = billboard

	-- Determinar duración y estilo según el modo
	local duration = 25
	local isCooldown = (mode == "cooldown")

	if isCooldown then
		duration = 60
		label.TextColor3 = Color3.fromRGB(255, 200, 50) -- Amarillo/naranja (corto circuito)
	else
		label.TextColor3 = Color3.fromRGB(255, 255, 255) -- Blanco normal
	end

	-- Crear efecto de chispas SOLO en modo cooldown
	local sparks
	if isCooldown then
		sparks = Instance.new("ParticleEmitter")
		sparks.Parent = promptPart
		sparks.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 220, 80)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 200))
		})
		sparks.Size = NumberSequence.new(0.15, 0.05)
		sparks.Lifetime = NumberRange.new(0.15, 0.45)
		sparks.Rate = 35
		sparks.Speed = NumberRange.new(4, 10)
		sparks.SpreadAngle = Vector2.new(360, 360)
		sparks.LightEmission = 1
		sparks.LightInfluence = 0
		sparks.Acceleration = Vector3.new(0, -15, 0)
	end

	-- Contador
	for i = duration, 1, -1 do
		if not label or not label.Parent then break end
		label.Text = i .. "s"

		-- Efecto de parpadeo rápido en cooldown
		if isCooldown then
			label.TextColor3 = (i % 2 == 0) 
				and Color3.fromRGB(255, 180, 30) 
				or Color3.fromRGB(255, 240, 100)
		end

		task.wait(1)
	end

	-- Limpiar todo al terminar
	if billboard and billboard.Parent then
		billboard:Destroy()
	end

	if sparks and sparks.Parent then
		sparks:Destroy()
	end

	print("Timer finalizado en base" .. baseNumber)
