--!strict
-- ModuleScript: TurretStats
-- Ubicación: ServerScriptService

local ServerScriptService = game:GetService("ServerScriptService")
local DataManager = require(ServerScriptService:WaitForChild("DataManager"))

local TurretStats = {}

-- Costos por nivel (índice = nivel al que subes)
local UPGRADE_COSTS = {100, 250, 500, 900, 1400, 2000, 2750, 3750, 5000, 7000}

-- Valores base
local DEFAULT_STATS = {
	Damage = 10,
	ProjectileSpeed = 450,
	ProjectileSize = 4,
	FireRate = 0.15,
	Range = 200,
	CritChance = 0,
	MultiShot = 1,
}

-- Cuánto sube cada stat por nivel
local UPGRADE_VALUES = {
	Damage = 10,
	ProjectileSpeed = 50,
	ProjectileSize = 0.5,
	FireRate = -0.01,
	Range = 50,
	CritChance = 0.03,
	MultiShot = 0.5,
}

local playerStats = {}

-- Inicializar stats (carga desde DataManager)
function TurretStats.Init(player)
	local data = DataManager.GetData(player)
	if not data then
		DataManager.LoadData(player)
		data = DataManager.GetData(player)
	end

	-- Si no existe la estructura correcta, la creamos
	if not data.Turret or not data.Turret.Stats or not data.Turret.Levels then
		data.Turret = {
			Stats = table.clone(DEFAULT_STATS),
			Levels = {
				Damage = 0,
				ProjectileSpeed = 0,
				ProjectileSize = 0,
				FireRate = 0,
				Range = 0,
				CritChance = 0,
				MultiShot = 0,
			}
		}
	end

	playerStats[player.UserId] = data.Turret
end

-- Obtener un stat actual
function TurretStats.Get(player, statName)
	local data = playerStats[player.UserId]
	if not data or not data.Stats then 
		return DEFAULT_STATS[statName] 
	end
	return data.Stats[statName]
end

-- Obtener nivel actual de un stat
function TurretStats.GetLevel(player, statName)
	local data = playerStats[player.UserId]
	if not data or not data.Levels then 
		return 0 
	end
	return data.Levels[statName]
end

-- Obtener costo del siguiente nivel
function TurretStats.GetUpgradeCost(player, statName)
	local currentLevel = TurretStats.GetLevel(player, statName)
	if currentLevel >= 10 then return nil end
	return UPGRADE_COSTS[currentLevel + 1]
end

-- Aplicar mejora y guardar en DataManager
function TurretStats.Upgrade(player, statName)
	local data = playerStats[player.UserId]
	if not data or not data.Stats or not data.Levels then 
		return false 
	end

	local currentLevel = data.Levels[statName]
	if currentLevel >= 10 then return false end

	-- Subir nivel
	data.Levels[statName] = currentLevel + 1

	-- Calcular nuevo valor del stat
	data.Stats[statName] = DEFAULT_STATS[statName] + (UPGRADE_VALUES[statName] * data.Levels[statName])

	-- Reglas especiales
	if statName == "MultiShot" then
		data.Stats[statName] = math.max(1, math.floor(DEFAULT_STATS.MultiShot + (UPGRADE_VALUES.MultiShot * data.Levels[statName])))
	end

	if statName == "FireRate" then
		data.Stats[statName] = math.max(0.05, data.Stats[statName])
	end

	-- Guardar cambios en DataManager
	DataManager.UpdateData(player, function(currentData)
		currentData.Turret = data
		return currentData
	end)

	return true
end

-- Limpiar cuando el jugador sale
function TurretStats.Remove(player)
	playerStats[player.UserId] = nil
end

return TurretStats



