AdminCommand.OnServerEvent:Connect(function(player, command, ...)
	if not isAdmin(player) then return end

	local args = {...}
	local textInputName = args[1]
	local target = getTargetPlayer(textInputName)

	if textInputName and textInputName ~= "" and textInputName ~= player.Name and not target then
		AdminResponse:FireClient(player, "❌ Error: Jugador '" .. tostring(textInputName) .. "' no encontrado.")
		return
	end

	if not target then target = player end

	-- OBTENER ACCESO DIRECTO A LA BASE DEL OBJETIVO
	local baseNumber = target:GetAttribute("BaseNumber")
	local base = baseNumber and Workspace:FindFirstChild("base" .. baseNumber)
	local innerBase = base and base:FindFirstChild("based") and base.based:FindFirstChild("base")

	if command == "AddEsencia" then
		local amount = tonumber(args[2]) or 0
		local esencia = target.leaderstats and target.leaderstats:FindFirstChild("Esencia")
		if esencia then setEsencia(target, esencia.Value + amount) end

	elseif command == "SetEsencia" then
		setEsencia(target, tonumber(args[2]) or 0)

		-- ==========================================
		-- NUEVO COMANDO: ClearSlot (ELIMINAR SLOT DINÁMICO 1-50+)
		-- ==========================================
	elseif command == "ClearSlot" then
		if not innerBase then
			AdminResponse:FireClient(player, "❌ El jugador no tiene base construida.")
			return
		end

		local slotInput = tonumber(args[2])
		if not slotInput then
			AdminResponse:FireClient(player, "❌ Debes escribir un número de slot válido en la caja de texto.")
			return
		end

		local targetSlotName = "slot" .. slotInput
		local slotPart = innerBase:FindFirstChild(targetSlotName)

		if not slotPart then
			AdminResponse:FireClient(player, "❌ Ese slot (" .. targetSlotName .. ") no existe en la base actual.")
			return
		end

		-- Usar SpiritUtils para encontrar el Spirit sin depender de nombre/tipo
		local spiritInSlot = SpiritUtils.GetSpiritInSlot(slotPart)
		local found = false

		if spiritInSlot then
			spiritInSlot:Destroy()
			found = true
		end

		slotPart:SetAttribute("IsOccupied", false)

		if found then
			AdminResponse:FireClient(player, "✅ Slot " .. slotInput .. " limpiado con éxito de la base de " .. target.Name)
		else
			AdminResponse:FireClient(player, "⚠ El slot " .. slotInput .. " ya estaba vacío.")
		end

		-- ==========================================
		-- NUEVO COMANDO: ClearAllSlots (LIMPIAR TODA LA BASE)
		-- ==========================================
	elseif command == "ClearAllSlots" then
		if not innerBase then
			AdminResponse:FireClient(player, "❌ Base no encontrada.")
			return
		end

		local count = 0
		-- Recorrer todos los slots y usar SpiritUtils para encontrar lo que tengan dentro
		for _, slotPart in ipairs(innerBase:GetChildren()) do
			if slotPart.Name:match("^slot%d+$") then
				local spiritInSlot = SpiritUtils.GetSpiritInSlot(slotPart)
				if spiritInSlot then
					spiritInSlot:Destroy()
					count += 1
				end
				slotPart:SetAttribute("IsOccupied", false)
			end
		end

		AdminResponse:FireClient(player, "✅ Se eliminaron " .. count .. " Espíritus de la base de " .. target.Name)

	elseif command == "SpawnSpirit" then
		local spiritName = args[2] or ""
		if spiritName == "" then
			AdminResponse:FireClient(player, "❌ Escribe el nombre del Spirit")
			return
		end
		local success, msg = spawnSpiritInBase(target, spiritName)
		AdminResponse:FireClient(player, msg)

		-- [Mantener el resto de comandos idénticos: ResetTurret, SetSpeed, Kick, Ban, ClearBoxes, etc.]
	elseif command == "ResetTurret" then
		local TurretStats = require(ServerScriptService:WaitForChild("TurretStats"))
		DataManager.UpdateData(target, function(data)
			data.Turret = {
				Stats = {Damage = 10, ProjectileSpeed = 450, ProjectileSize = 4, FireRate = 0.15, Range = 200, CritChance = 0, MultiShot = 1},
				Levels = {Damage = 0, ProjectileSpeed = 0, ProjectileSize = 0, FireRate = 0, Range = 0, CritChance = 0, MultiShot = 0}
			}
			return data
		end)
		TurretStats.Init(target)
		AdminResponse:FireClient(player, "✅ Torreta de " .. target.Name .. " reiniciada")
	elseif command == "SetSpeed" then
		local speed = tonumber(args[2]) or 16
		target:SetAttribute("AdminSpeed", speed)
		local character = target.Character
		local humanoid = character and character:FindFirstChild("Humanoid")
		if humanoid then humanoid.WalkSpeed = speed end
		AdminResponse:FireClient(player, "✅ Velocidad modificada")
	elseif command == "SpawnBox" then
		local rarityName = args[1] or "Comun"
		rarityName = rarityName:sub(1,1):upper() .. rarityName:sub(2):lower()
		if rarityName == "Poco comun" then rarityName = "Poco Comun" end
		if _G.SpawnAdminBox then _G.SpawnAdminBox(rarityName) AdminResponse:FireClient(player, "✅ Caja " .. rarityName .. " spawneada") end
	elseif command == "ClearBoxes" then
		for _, obj in ipairs(Workspace:GetChildren()) do if obj.Name:find("Caja_") then obj:Destroy() end end
		AdminResponse:FireClient(player, "✅ Cajas eliminadas")
	end
end)

