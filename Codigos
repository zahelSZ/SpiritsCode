local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ServerScriptService = game:GetService("ServerScriptService")
local SpiritUtils = require(ServerScriptService:WaitForChild("SpiritUtils"))
local DataManager = require(ServerScriptService:WaitForChild("DataManager"))
local SpiritPositionManager = require(ServerScriptService:WaitForChild("SpiritPositionManager"))

-- 🆕 ENLACE AL SPEEDMANAGER PARA QUITAR LA LENTITUD AL DEPOSITAR
local SpeedManager = require(ServerScriptService:WaitForChild("SpeedManager"))

local carrying = _G.CarryingSpirits or {}
_G.CarryingSpirits = carrying

for i = 1, 8 do
	local base = Workspace:FindFirstChild("base" .. i)
	if base then
		local depositZone = base:FindFirstChild("SpiritDepositZone")

		if depositZone and depositZone:IsA("BasePart") then
			depositZone.Touched:Connect(function(hit)
				local character = hit.Parent
				local player = Players:GetPlayerFromCharacter(character)
				if not player then return end

				if player:GetAttribute("BaseNumber") ~= i then return end

				local spirit = carrying[player]
				if not spirit or not spirit.Parent then return end

				if spirit:GetAttribute("FromSlot") then return end

				-- Buscar slot vacío
				local slotFound = nil
				local slotNumber = nil
				for s = 1, 10 do
					local slot = base:FindFirstChild("based")
						and base.based:FindFirstChild("base")
						and base.based.base:FindFirstChild("slot" .. s)

					if slot and slot:IsA("BasePart") and not SpiritUtils.GetSpiritInSlot(slot) then
						slotFound = slot
						slotNumber = s
						break
					end
				end

				if not slotFound then
					print("[SpiritDeposit] No hay slots disponibles en base " .. i)
					return
				end

				-- Depositar
				print("[SpiritDeposit] " .. player.Name .. " depositó un Spirit en " .. slotFound.Name)

				spirit.Name = "Spirit"

				-- ✨ CORRECCIÓN 1: Usar 'slotFound' en lugar de 'slot' para que Blender sepa dónde acomodarlo
				SpiritPositionManager.PlaceInSlot(spirit, slotFound)

				-- Mantenemos las utilidades por si ejecutan configuraciones extra en el modelo
				SpiritUtils.SetAnchored(spirit, true)
				SpiritUtils.SetCanCollide(spirit, false)

				spirit:SetAttribute("IsBeingCarried", nil)
				spirit:SetAttribute("FromSlot", true)
				spirit:SetAttribute("SpiritState", "Base")
				carrying[player] = nil
				player:SetAttribute("IsCarryingSpirit", false)

				-- ✨ CORRECCIÓN 2: Limpiar estado de velocidad para que el jugador vuelva a correr a 22
				if character then
					character:SetAttribute("HasSpirit", false)
				end
				SpeedManager.UpdateSpeed(player)

				-- GUARDAR en DataManager
				local spiritName = spirit:GetAttribute("SpiritName") or spirit.Name
				local accumulated = spirit:GetAttribute("AccumulatedEssence") or 0
				DataManager.SaveSpiritToSlot(player, i, slotNumber, spiritName, accumulated)
				print("[SpiritDeposit] Spirit guardado en DataManager: base" .. i .. " slot" .. slotNumber)
				DataManager.ClearHeldSpirit(player)
				print("[SpiritDeposit] HeldSpirit limpiado")

				local setupModule = _G.SetupOrbPickup
				if setupModule then
					setupModule(spirit)
				end
			end)
		end
	end
end

