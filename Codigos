		Levels = { Damage = 0, ProjectileSpeed = 0, ProjectileSize = 0, FireRate = 0, Range = 0, CritChance = 0, MultiShot = 0 }
	},

	Spirits = {},
	Equipos = {}
}

-- ========================================================
-- FUNCIONES INTERNAS
-- ========================================================
local function reconcile(target, template)
	for key, value in pairs(template) do
		if target[key] == nil then
			target[key] = type(value) == "table" and {} or value
			if type(value) == "table" then reconcile(target[key], value) end
		elseif type(value) == "table" and type(target[key]) == "table" then
			reconcile(target[key], value)
		end
	end
end

local function deepCopy(tbl)
	local copy = {}
	for k, v in pairs(tbl) do
		copy[k] = type(v) == "table" and deepCopy(v) or v
	end
	return copy
end

-- ========================================================
-- LOAD / SAVE
-- ========================================================
function DataManager.LoadData(player)
	local key = "Player_" .. player.UserId
	local success, result = pcall(function()
		return PlayerDataStore:GetAsync(key)
	end)

	local data = success and result or deepCopy(DEFAULT_DATA)
	if not success or not result then
		data = deepCopy(DEFAULT_DATA)
	end

	reconcile(data, DEFAULT_DATA)
	data.LastLogin = os.time()
	sessionData[player] = data
	return data
end

function DataManager.SaveData(player)
	local data = sessionData[player]
	if not data then return end
	pcall(function()
		PlayerDataStore:SetAsync("Player_" .. player.UserId, data)
	end)
end

