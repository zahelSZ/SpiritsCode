local function findSpiritData(spiritName)
	for _, s in ipairs(SpiritDatabase) do
		if s.Name:lower() == spiritName:lower() then return s end
	end
	return nil
end

-- ==========================================
-- CREACIÓN DINÁMICA DE TEXTO Y PROMPT (NUEVO)
-- ==========================================
local function applySpiritVisualsAndPrompt(spirit, spiritData, targetSlot, targetPlayer)
	-- 1. Crear el BillboardGui para las estadísticas flotantes
	local bbGui = Instance.new("BillboardGui")
	bbGui.Name = "SpiritStatsUI"
	bbGui.Size = UDim2.new(0, 200, 0, 50)
	bbGui.StudsOffset = Vector3.new(0, 3.5, 0)
	bbGui.AlwaysOnTop = true

	local textLabel = Instance.new("TextLabel")
	textLabel.Size = UDim2.new(1, 0, 1, 0)
	textLabel.BackgroundTransparency = 1
	textLabel.TextScaled = true
	textLabel.Font = Enum.Font.GothamBold
	textLabel.TextColor3 = RarityColors[spiritData.Rarity] or Color3.fromRGB(255, 255, 255)
	textLabel.TextStrokeTransparency = 0
	textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	textLabel.Text = spiritData.Name .. "\n⚡ +" .. spiritData.EssenceRate .. "/s"
	textLabel.Parent = bbGui
	bbGui.Parent = spirit

	-- 2. Crear el ProximityPrompt para poder levantarlo manualmente
	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = "PickupPrompt"
	prompt.ObjectText = spiritData.Name
	prompt.ActionText = "Recoger Espíritu"
	prompt.HoldDuration = 0.2
	prompt.MaxActivationDistance = 12
	prompt.UIOffset = Vector2.new(0, 15)

	-- Vincular la recogida física
	prompt.Triggered:Connect(function(clickingPlayer)
		if clickingPlayer == targetPlayer or isAdmin(clickingPlayer) then
			targetSlot:SetAttribute("IsOccupied", false)

			-- Activar el retraso de peso en el jugador que lo recoja
			local char = clickingPlayer.Character
			if char then
				char:SetAttribute("HasSpirit", true)
			end

			spirit:Destroy()
		end
	end)

	-- Buscar la parte principal para meterle el prompt
	local root = spirit:FindFirstChild("HumanoidRootPart") or spirit:FindFirstChildOfClass("BasePart")
	if root then
		prompt.Parent = root
	else
		prompt.Parent = spirit
	end
end

-- ==========================================
-- SPAWN SPIRIT EN BASE
-- ==========================================
local function spawnSpiritInBase(targetPlayer, spiritName)
	local baseNumber = targetPlayer:GetAttribute("BaseNumber")
	if not baseNumber then return false, "❌ El jugador no tiene base asignada" end

	local spiritData = findSpiritData(spiritName)
	if not spiritData then return false, "❌ Spirit no encontrado: " .. spiritName end

	local rarityFolder = SpiritTemplate:FindFirstChild(spiritData.Rarity)
	if not rarityFolder then return false, "❌ Carpeta de rareza no encontrada: " .. spiritData.Rarity end

	local model = rarityFolder:FindFirstChild(spiritData.Name)
	if not model then return false, "❌ Modelo no encontrado: " .. spiritData.Name end

	local base = Workspace:FindFirstChild("base" .. baseNumber)
	if not base then return false, "❌ Base física de juego no encontrada" end

	local based = base:FindFirstChild("based")
	local innerBase = based and based:FindFirstChild("base")
	if not innerBase then return false, "❌ Estructura de base rota" end

	local targetSlot = nil
	local finalSlotIndex = 0

	-- Analizar dinámicamente hasta 100 slots sin importar cuántos Rebirths agregues
	for i = 1, 100 do
		local slot = innerBase:FindFirstChild("slot" .. i)
		if slot and not SpiritUtils.GetSpiritInSlot(slot) and not slot:GetAttribute("IsOccupied") then
			targetSlot = slot
			finalSlotIndex = i
			break
		end
	end

	if not targetSlot then return false, "❌ No hay slots disponibles en la base" end

	local spirit = model:Clone()
	spirit.Name = "Spirit"

	-- Fijamos la marca del slot para poder rastrearlo o borrarlo por comando individual
	spirit:SetAttribute("AssignedSlotName", "slot" .. finalSlotIndex)

	spirit:PivotTo(CFrame.new(targetSlot.Position + Vector3.new(0, 3, 0)))
	spirit.Parent = innerBase

	if SpiritPositionManager and SpiritPositionManager.PlaceInSlot then
		SpiritPositionManager.PlaceInSlot(spirit, targetSlot)
	end

	spirit:SetAttribute("Rarity", spiritData.Rarity)
	spirit:SetAttribute("EssenceRate", spiritData.EssenceRate)
	spirit:SetAttribute("SpiriumValue", spiritData.SpiriumValue)
	spirit:SetAttribute("SpiritName", spiritData.Name)
	spirit:SetAttribute("SpiritState", "Base")
	spirit:SetAttribute("FromSlot", true)

	local br = Instance.new("ObjectValue")
	br.Name = "Breaker"
	br.Value = targetPlayer
	br.Parent = spirit

	-- INYECTAR TEXTO FLOTANTE Y PROMPT
	applySpiritVisualsAndPrompt(spirit, spiritData, targetSlot, targetPlayer)

	if _G.SetupOrbPickup then
		_G.SetupOrbPickup(spirit)
	end

	return true, "✅ " .. spiritData.Name .. " en slot " .. finalSlotIndex .. " (Base " .. baseNumber .. ")"
end

