		textLabel.TextColor3 = Color3.fromRGB(255, 30, 30)
		textLabel.TextSize = 28
	else
		textLabel.TextColor3 = Color3.fromRGB(255, 160, 20) -- Naranja/Amarillo estándar
	end

	-- Borde negro para que se lea perfecto en cualquier fondo del mapa
	textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	textLabel.TextStrokeTransparency = 0
	textLabel.Parent = billboard

	-- ========================================================
	-- ANIMACIÓN: CURVA EN U INVERTIDA (ARCO PARABÓLICO) Y FADE
	-- ========================================================
	task.spawn(function()
		local duration = 0.75 -- Cuánto dura el número flotando
		local elapsed = 0

		-- Dirección aleatoria hacia los lados para que los números no se encimen si disparas rápido
		local driftX = math.random(-3, 3)
		local driftZ = math.random(-3, 3)

		while elapsed < duration do
			local dt = task.wait()
			elapsed += dt
			local progress = elapsed / duration

			-- 1. Movimiento en U invertida usando la función Seno (Sube y luego baja un poco)
			local currentY = math.sin(progress * math.pi) * 5

			-- 2. Movimiento horizontal constante
			local currentX = driftX * progress
			local currentZ = driftZ * progress

			-- Aplicar el desplazamiento en el espacio del mundo
			billboard.StudsOffsetWorldSpace = Vector3.new(currentX, currentY, currentZ)

			-- 3. Efecto Fade Out (Comienza a desvanecerse a la mitad del camino)
			if progress > 0.4 then
				local fadeProgress = (progress - 0.4) / 0.6
				textLabel.TextTransparency = fadeProgress
				textLabel.TextStrokeTransparency = fadeProgress
			end
		end

		-- Limpieza absoluta de memoria
		billboard:Destroy()
		attachment:Destroy()
	end)
end)

