end

function SpiritUtils.SetAnchored(spirit: Instance, anchored: boolean)
	if spirit:IsA("BasePart") then
		spirit.Anchored = anchored
	elseif spirit:IsA("Model") then
		for _, part in ipairs(spirit:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Anchored = anchored
			end
		end
	end
end

function SpiritUtils.PlaceInSlot(spirit: Instance, slot: BasePart)
	local primary = SpiritUtils.GetPrimaryPart(spirit)
	if not primary then return end

	-- Rotación correctiva para los modelos
	local correctiveRotation = CFrame.Angles(math.rad(-90), 0, 0) 

	local targetCFrame = slot.CFrame * CFrame.new(0, 2.5, 0) * correctiveRotation
	SpiritUtils.SetCFrame(spirit, targetCFrame)
end

function SpiritUtils.UpdateCarriedOrientation(spirit: Instance, player: Player)
	local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	-- Offset + rotación para que mire hacia adelante
	local offset = CFrame.new(0, 0.8, -3.2) 
		* CFrame.Angles(math.rad(-20), math.rad(180), 0) 

	SpiritUtils.SetCFrame(spirit, hrp.CFrame * offset)
end

function SpiritUtils.SetCanCollide(spirit: Instance, canCollide: boolean)
	if spirit:IsA("BasePart") then
		spirit.CanCollide = canCollide
	elseif spirit:IsA("Model") then
		for _, part in ipairs(spirit:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CanCollide = canCollide
			end
		end
	end
end

function SpiritUtils.SetCFrame(spirit: Instance, cframe: CFrame)
	local primary = SpiritUtils.GetPrimaryPart(spirit)
	if not primary then return end

	if spirit:IsA("Model") then
		spirit:PivotTo(cframe)
	else
		primary.CFrame = cframe
	end
end

function SpiritUtils.ClearVelocities(spirit: Instance)
	if spirit:IsA("BasePart") then
		spirit.Velocity = Vector3.zero
		spirit.AssemblyLinearVelocity = Vector3.zero
		spirit.AssemblyAngularVelocity = Vector3.zero
	elseif spirit:IsA("Model") then
		for _, part in ipairs(spirit:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Velocity = Vector3.zero
				part.AssemblyLinearVelocity = Vector3.zero
				part.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end
end

function SpiritUtils.SetupSpirit(spirit: Instance)
	SpiritUtils.GetPrimaryPart(spirit) -- Fuerza la asignación automática si falta
end

-- Detecta si un objeto es un Spirit basándose en atributos
function SpiritUtils.IsSpirit(instance: Instance): boolean
	if not instance then return false end
	return instance:GetAttribute("SpiritState") ~= nil
		or instance:GetAttribute("EssenceRate") ~= nil
end

-- Obtiene el Spirit dentro de un slot si existe (¡YA PURGADO!)
function SpiritUtils.GetSpiritInSlot(slot: Instance): Instance?
	if not slot then return nil end
	for _, child in ipairs(slot:GetChildren()) do
		if SpiritUtils.IsSpirit(child) then
			return child
		end
	end
	return nil
end

return SpiritUtils

