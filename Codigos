local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local BASE_PREFIX = "base"
local FUSEBOX_NAME = "caja de fusible"
local PROMPT_PART_NAME = "PromptPart"
local BARRIER_NAME = "Barrier"

local OPEN_TIME = 25
local COOLDOWN_TIME = 60

local OpenBaseEvent = ReplicatedStorage:WaitForChild("OpenBaseEvent")
local StartMiniGameEvent = ReplicatedStorage:WaitForChild("StartMiniGameEvent")
local MiniGameResultEvent = ReplicatedStorage:WaitForChild("MiniGameResultEvent")

local basesData = {}

-- ====================== FUNCIONES ======================

local function setBarrierCollision(barrier, canCollide)
	if not barrier then return end

	-- CASO 1: Si la barrera principal es la pieza física en sí
	if barrier:IsA("BasePart") then
		barrier.CanCollide = canCollide
	end

	-- CASO 2: Por si acaso en el futuro metes sub-partes dentro
	for _, part in ipairs(barrier:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = canCollide
		end
	end
end

local function setLasersVisible(lasers, visible)
	if not lasers then return end
	for _, laser in ipairs(lasers) do
		if laser:IsA("BasePart") then
			laser.Transparency = visible and 0 or 1
			-- 🚨 CORREGIDO: Los láseres NUNCA deben tener colisión física
			laser.CanCollide = false 
		end
	end
end


local function closeBase(baseId)
	local data = basesData[baseId]
	if not data then return end

	setBarrierCollision(data.barrier, true)
	setLasersVisible(data.lasers, true)

	data.state = "cooldown"
	data.openTimer = nil

	OpenBaseEvent:FireAllClients(baseId, "cooldown")

	data.cooldownTimer = task.delay(COOLDOWN_TIME, function()
		data.state = "ready"
		if data.prompt then data.prompt.Enabled = true end
		data.cooldownTimer = nil
	end)
end

local function startOpening(baseId)
	local data = basesData[baseId]
	if not data or data.state ~= "ready" then return end

	data.state = "opening"
	if data.prompt then data.prompt.Enabled = false end

	setBarrierCollision(data.barrier, false)
	setLasersVisible(data.lasers, false)

	OpenBaseEvent:FireAllClients(baseId)

	data.openTimer = task.delay(OPEN_TIME, function()
		closeBase(baseId)
	end)
end

