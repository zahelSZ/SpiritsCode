	player.CharacterAdded:Connect(function()
		task.wait(1)
		local playerGui = player:FindFirstChildOfClass("PlayerGui")
		if playerGui and not playerGui:FindFirstChild("AdminGui") then
			local adminGui = ServerStorage:FindFirstChild("AdminGui")
			if adminGui then
				local clone = adminGui:Clone()
				clone.Parent = playerGui
			end
		end
	end)
