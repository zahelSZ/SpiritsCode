			local offset = CFrame.new(0, 0.8, -3.2) * CFrame.Angles(math.rad(-20), 0, 0)
			SpiritUtils.UpdateCarriedOrientation(spirit, player)
		end)

		carryConnections[player] = connection
	end)
end

