local YAW_OFFSET = math.rad(-90)
local MAX_PITCH = math.rad(80)
local MIN_PITCH = math.rad(-15)

-- Función mejorada: encuentra el cañón según en qué base estás sentado
local function obtenerCanon()
	local char = player.Character
	local hum = char and char:FindFirstChild("Humanoid")
	if not hum or not hum.SeatPart then return nil end

	local seat = hum.SeatPart

	local current = seat
	while current do
		if current.Name:match("^base%d+$") then
			local torreta = current:FindFirstChild("torreta")
			if torreta then
				return torreta:FindFirstChild("cañon")
			end
		end
		current = current.Parent
	end
	return nil
end

local function puedeUsarTurreta()
	local char = player.Character
	local hum = char and char:FindFirstChild("Humanoid")
	if not hum or not hum.SeatPart then return false end

	local seat = hum.SeatPart
	local current = seat

	while current do
		if current.Name:match("^base%d+$") then
			local baseNum = tonumber(current.Name:match("%d+"))
			local playerBase = player:GetAttribute("BaseNumber")
			return baseNum == playerBase
		end
		current = current.Parent
	end
	return false
end

local function estaSentado()
	local char = player.Character
	local hum = char and char:FindFirstChild("Humanoid")
	return hum and hum.SeatPart and hum.SeatPart.Name == "asiento"
end

-- ==================== DETECTAR CLICK Y HOLD ====================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		isHoldingMouse = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		isHoldingMouse = false
	end
end)

RunService.RenderStepped:Connect(function()
	local sentado = estaSentado()
	local esDueno = puedeUsarTurreta()
	local isCarrying = player:GetAttribute("IsCarryingSpirit") or false

	-- ====================== CONTROL DE CRUCETA ======================
	if sentado and esDueno and not isCarrying then
		showCrosshair()
	else
		hideCrosshair()
	end

	if sentado then
		if not esDueno or isCarrying then
			local hum = player.Character and player.Character:FindFirstChild("Humanoid")
			if hum then
				hum.Sit = false
			end
			return
		end

		if not canon then
			canon = obtenerCanon()
			if canon then
				initialCFrame = canon.CFrame
				player.CameraMode = Enum.CameraMode.LockFirstPerson
			end
		end
	end

	if canon then
		if sentado and esDueno and not isCarrying then
			-- ==================== APUNTADO ====================
			local lookDirection = camera.CFrame.LookVector
			local pitch = math.asin(math.clamp(lookDirection.Y, -1, 1))
			pitch = math.clamp(pitch, MIN_PITCH, MAX_PITCH)

			local flatDir = Vector3.new(lookDirection.X, 0, lookDirection.Z).Unit
			local finalDir = flatDir * math.cos(pitch) + Vector3.new(0, math.sin(pitch), 0)

			local targetCFrame = CFrame.lookAt(canon.Position, canon.Position + finalDir)
				* CFrame.Angles(0, YAW_OFFSET, 0)

			canon.CFrame = canon.CFrame:Lerp(targetCFrame, 0.3)

			-- ==================== DISPARO CONTINUO ====================
			if isHoldingMouse and tick() - lastShot >= FIRE_RATE then
				lastShot = tick()
				local shootDirection = finalDir
				local firePos = canon.Position + shootDirection * (canon.Size.Z / 2 + 2)
				ShootEvent:FireServer(firePos, shootDirection)
			end

		else
			if initialCFrame then
				canon.CFrame = canon.CFrame:Lerp(initialCFrame, 0.2)
				if (canon.CFrame.LookVector - initialCFrame.LookVector).Magnitude < 0.04 then
					canon.CFrame = initialCFrame
					canon = nil
					initialCFrame = nil
					player.CameraMode = Enum.CameraMode.Classic
				end
			end
		end
	end
end)

