		local basedFolder = baseModel:FindFirstChild("based")
		if not basedFolder then continue end

		local fuseContainer = basedFolder:FindFirstChild(FUSEBOX_NAME)
		if not fuseContainer then continue end

		local promptPart = fuseContainer:FindFirstChild(PROMPT_PART_NAME) or fuseContainer
		local prompt = promptPart:FindFirstChildOfClass("ProximityPrompt")

		local barrier = baseModel:FindFirstChild(BARRIER_NAME)

		local lasers = {}
		local innerBase = basedFolder:FindFirstChild("base")
		if innerBase then
			for _, obj in ipairs(innerBase:GetChildren()) do
				if obj:IsA("BasePart") and string.lower(obj.Name):find("laser") then
					table.insert(lasers, obj)
				end
			end
		end

		basesData[i] = {
			model = baseModel,
			prompt = prompt,
			barrier = barrier,
			lasers = lasers,
			state = "ready",
			currentHacker = nil,
			openTimer = nil,
			cooldownTimer = nil,
		}

		if prompt then
			prompt.Enabled = true

			prompt.Triggered:Connect(function(player)
				local data = basesData[i]
				if not data or data.state ~= "ready" then return end

				-- =============================================
				-- NUEVO: El dueño no puede hackear su propia base
				-- =============================================
				if player:GetAttribute("BaseNumber") == i then
					return
				end

				data.currentHacker = player
				prompt.Enabled = false
				StartMiniGameEvent:FireClient(player, i)
			end)
		end
	end
end

