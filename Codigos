	local baseModel = Workspace:FindFirstChild("base" .. i) or Workspace:FindFirstChild("Base" .. i)
	if baseModel then
		local barrier = baseModel:FindFirstChild("Barrier") or baseModel:FindFirstChild("barrier")
		if barrier then
			local groupName = "Barrier" .. i

			-- CASO 1: Si la Barrera es un solo bloque físico directo (Part, MeshPart, etc.)
			if barrier:IsA("BasePart") then
				barrier.CollisionGroup = groupName
				barrier.CanCollide = true
			end

			-- CASO 2: Si la Barrera es un Modelo o Carpeta con sub-partes adentro
			for _, part in ipairs(barrier:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CollisionGroup = groupName
					part.CanCollide = true
				end
			end
		end
	end
end

