local function loadSpiritsForPlayer(player)
	local baseNumber = player:GetAttribute("BaseNumber")
	if not baseNumber then return end

	-- HELD SPIRIT
	local heldSpirit: any = nil
	if DataManager and typeof(DataManager.GetHeldSpirit) == "function" then
		heldSpirit = DataManager.GetHeldSpirit(player)
	end

	if heldSpirit then
		local prevBase = tonumber(heldSpirit.PreviousBase)
		local prevSlot = tonumber(heldSpirit.PreviousSlot)

		if prevBase and prevSlot and prevBase == baseNumber then
			local base = Workspace:FindFirstChild("base" .. prevBase)
			local baseFolder = base and base:FindFirstChild("based") and base.based:FindFirstChild("base")

			local spiritName = heldSpirit.SpiritName
			local spiritData = findSpiritData(spiritName)

			if not spiritData then
				warn("[SpiritLoader] Spirit no encontrado en SpiritDatabase:", tostring(spiritName))
			else
				local originalSlot = baseFolder and baseFolder:FindFirstChild("slot" .. prevSlot)

