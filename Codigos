local function setupProximityDetection()
	local baseNumber = player:GetAttribute("BaseNumber")
	if not baseNumber then 
		warn("[TurretUpgradeClient] El jugador no tiene el atributo BaseNumber asignado.")
		return 
	end

	-- 1. Esperamos de forma segura al modelo de la base en el Workspace
	local baseFolder = Workspace:WaitForChild("base" .. baseNumber, 15)
	if not baseFolder then 
		warn("[TurretUpgradeClient] No se encontró en el Workspace: base" .. baseNumber)
		return 
	end

	-- 2. Esperamos de forma segura al modelo/carpeta 'Upgrades'
	local upgradesFolder = baseFolder:WaitForChild("Upgrades", 10)
	if not upgradesFolder then
		warn("[TurretUpgradeClient] Falta el objeto 'Upgrades' dentro de base" .. baseNumber)
		return
	end

	-- 3. Buscamos 'TurretUpgrades' (en plural, tal como lo tienes en tu juego)
	local upgradeWall = upgradesFolder:WaitForChild("TurretUpgrades", 10)
	if not upgradeWall or not upgradeWall:IsA("BasePart") then 
		warn("[TurretUpgradeClient] Falta la parte 'TurretUpgrades' (en plural) dentro de Upgrades.")
		return 
	end

	-- 4. Limpiamos prompts antiguos para evitar duplicados
	local existingPrompt = upgradeWall:FindFirstChildOfClass("ProximityPrompt")
	if existingPrompt then existingPrompt:Destroy() end

	-- 5. Creamos el detector nativo corregido
	local prompt = Instance.new("ProximityPrompt")
	prompt.MaxActivationDistance = 10               -- Rango de 10 studs
	prompt.Style = Enum.ProximityPromptStyle.Custom   -- Mantiene tu UI personalizada e invisible la de Roblox
	prompt.ActionText = "Mejorar"
	prompt.ObjectText = "Torreta"
	prompt.Parent = upgradeWall

	-- Evento: Al entrar al rango
	prompt.PromptShown:Connect(function()
		if not manuallyClosed then
			screenGui.Enabled = true
		end
	end)

	-- Evento: Al salir del rango
	prompt.PromptHidden:Connect(function()
		screenGui.Enabled = false
		manuallyClosed = false 
	end)

	print("✅ [TurretUpgradeClient] ¡Detector activado con éxito en TurretUpgrades de base" .. baseNumber .. "!")
end

-- Inicializar la detección al cargar la base
if player:GetAttribute("BaseNumber") then
	setupProximityDetection()
else
	player:GetAttributeChangedSignal("BaseNumber"):Connect(function()
		if player:GetAttribute("BaseNumber") then
			setupProximityDetection()
		end
	end)
end

